# Configuration mobile (publique cote client - elles seront embarquees dans le bundle).
# Copier en .env.local et remplir.
#
# Toutes les variables EXPO_PUBLIC_* sont injectees par Metro au build.

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optionnel : URL explicite du backend Hono (sinon auto-detection LAN en dev)
# EXPO_PUBLIC_API_URL=https://mealendar-api.example.workers.dev
